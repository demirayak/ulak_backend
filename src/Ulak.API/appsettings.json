{
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5433;Database=ulak_dev;Username=postgres;Password=1234"
  },

"Serilog": {
  "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Elasticsearch" ],
  "WriteTo": [
    { "Name": "Console" },
    { "Name": "File", "Args": { "path": "logs/log-.txt", "rollingInterval": "Day" } },
    {
      "Name": "Elasticsearch",
      "Args": {
        "nodeUris": "http://localhost:9200",
        "indexFormat": "ulak-logs-{0:yyyy.MM.dd}",
        "autoRegisterTemplate": true,
        "numberOfShards": 1,
        "numberOfReplicas": 0,
        "failureCallback": "Console.WriteLine('Elastic error occurred')",
        "emitEventFailure": "WriteToSelfLog"
      }
    }
  ]
}
}